{
    "name": "monorepo-exo",
    "version": "1.0.0",
    "description": "Tableau de bord GitHub Pages pour les exercices en monorepo",
    "main": "dist/generate-dashboard.js",
    "type": "module",
    "scripts": {
        "prepare": "cp hooks/pre-commit .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit",
        "build": "tsc",
        "start": "node dist/generate-dashboard.js",
        "build:dashboard": "npm run build && npm run start"
    },
    "keywords": [],
    "author": "Romain Dugeay",
    "license": "CC-BY-4.0",
    "devDependencies": {
        "@types/node": "^22.15.2",
        "typescript": "^5.8.3"
    }
}
